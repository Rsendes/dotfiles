sort=-priority
on-button-left=invoke-default-action
on-button-right=dismiss-all
on-button-middle=dismiss

font=Fira Sans 13
background-color=#000000AA
border-color=#ffffff1a
border-radius=8
border-size=1
text-color=#ffffffee
padding=12,16
margin=66,16,0

max-icon-size=32
icon-path=/usr/share/icons/Papirus-Dark

[urgency=low]
border-color=#ffffff1a

[urgency=normal]
border-color=#33ccffaa

[urgency=high]
border-color=#f53c3caa
text-color=#ffffff

[mode=do-not-disturb]
invisible=1
